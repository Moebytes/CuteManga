    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-draggable": "^4.5.0",
    "react-intersection-observer": "^10.0.3",
    "react-pdf": "^5.7.2",
    "react-redux": "^9.2.0",
    "react-router-hash-link": "^2.4.3",
