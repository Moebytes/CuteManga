{
  "name": "cutemanga",
  "version": "1.0.0",
  "description": "Learn Japanese by reading manga!",
  "main": "server.ts",
  "scripts": {
    "start": "npm run clean && rsbuild build && node server.ts",
    "build": "npm run clean && rsbuild build && npm run redirects",
    "redirects": "echo \"/* /index.html 200\" | cat > dist/_redirects",
    "server": "rsbuild build && npm run pm2",
    "pm2": "pm2 stop all && pm2 start server.ts",
    "clean": "del-cli ./dist"
  },
  "keywords": [
    "cute",
    "manga",
    "learn japanese",
    "japanese learning"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Moebytes/CuteManga"
  },
  "author": "Moebytes",
  "license": "CC BY-NC 4.0",
  "devDependencies": {
    "@babel/runtime": "^7.28.6",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-less": "^1.6.0",
    "@rsbuild/plugin-node-polyfill": "^1.4.4",
    "@rsbuild/plugin-react": "^1.4.5",
    "@svgr/webpack": "^8.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-pdf": "^5.7.2",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-slider": "^1.3.6",
    "@types/react-window": "^2.0.0",
    "del-cli": "^7.0.0",
    "dotenv": "^17.3.1",
    "express-favicon": "^2.0.4",
    "pm2": "^6.0.14",
    "react-router-dom": "^7.13.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "gibberish-detector": "^1.0.0",
